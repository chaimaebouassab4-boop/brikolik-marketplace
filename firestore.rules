rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isWhitelistedAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && exists(
          /databases/$(database)/documents/admin_emails/$(request.auth.token.email)
        );
    }

    function isAdmin() {
      return isWhitelistedAdminEmail()
        || (
          isSignedIn()
          && get(
            /databases/$(database)/documents/users/$(request.auth.uid)
          ).data.role == 'admin'
        );
    }

    function isVerifiedUser() {
      return isSignedIn()
        && get(
          /databases/$(database)/documents/users/$(request.auth.uid)
        ).data.isVerified == true;
    }

    function verificationFields() {
      return [
        'isVerified',
        'verificationRequested',
        'verificationRequestedAt',
        'verificationStatus',
        'verifiedAt',
        'rejectedAt',
        'verificationReason',
        'verifiedBy'
      ];
    }

    function ownerEditableFields() {
      return [
        'fullName',
        'phone',
        'bio',
        'city',
        'services',
        'photoUrl',
        'portfolioPhotoUrls',
        'portfolioPhotosCount',
        'portfolioUpdatedAt',
        'updatedAt',
        'role'
      ];
    }

    function ownerUpdateIsSafe() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      let roleAllowed = !('role' in request.resource.data)
        || request.resource.data.role in ['customer', 'worker']
        || (
          request.resource.data.role == 'admin'
          && isWhitelistedAdminEmail()
        );
      let touchesWorkerFields = changed.hasAny(['bio', 'services']);
      let canEditWorkerFields =
        !touchesWorkerFields || resource.data.isVerified == true;

      return changed.hasOnly(ownerEditableFields())
        && !changed.hasAny(verificationFields())
        && roleAllowed
        && canEditWorkerFields;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && (
          (
            request.resource.data.isVerified == false
            && request.resource.data.verificationRequested == false
            && (
              !('role' in request.resource.data)
              || request.resource.data.role in ['customer', 'worker']
            )
          )
          || (
            isWhitelistedAdminEmail()
            && request.resource.data.role == 'admin'
            && request.resource.data.isVerified == true
            && request.resource.data.verificationRequested == false
            && request.resource.data.verificationStatus == 'approved'
          )
        );

      allow read: if isSignedIn();
      allow update: if isAdmin() || (isOwner(userId) && ownerUpdateIsSafe());
      allow delete: if isAdmin() || isOwner(userId);
    }

    match /jobs/{jobId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.customerId == request.auth.uid
            || resource.data.acceptedWorkerId == request.auth.uid
            || resource.data.workerId == request.auth.uid
          )
        );
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.customerId == request.auth.uid);

      match /offers/{offerId} {
        allow read: if isSignedIn();
        allow create: if isVerifiedUser();
        allow update: if isAdmin()
          || (
            isSignedIn()
            && (
              resource.data.workerId == request.auth.uid
              || resource.data.customerId == request.auth.uid
            )
          );
        allow delete: if isAdmin()
          || (isSignedIn() && resource.data.workerId == request.auth.uid);
      }
    }

    // Requis pour les requetes collectionGroup('offers') du dashboard admin.
    // Sans cette regle recursive, Firestore peut refuser les lectures des
    // sous-collections offers meme si /jobs/{jobId}/offers/{offerId} existe.
    match /{path=**}/offers/{offerId} {
      allow read: if isSignedIn();
      allow create: if isVerifiedUser();
      allow update: if isAdmin()
        || (
          isSignedIn()
          && (
            resource.data.workerId == request.auth.uid
            || resource.data.customerId == request.auth.uid
          )
        );
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.workerId == request.auth.uid);
    }

    // Queue d'envoi d'emails (via l'extension Firebase Trigger Email)
    match /mail/{mailId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['to', 'message']);
      allow read, update, delete: if isAdmin();
    }

    // Avis apres mission: le client peut noter l'artisan une fois la mission finie.
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid
        && request.resource.data.keys().hasAll([
          'jobId',
          'customerId',
          'workerId',
          'quality',
          'punctuality',
          'communication',
          'average',
          'createdAt'
        ]);
      allow delete: if isAdmin();
    }

    // Notifications in-app: nouvelle offre, mission acceptee, urgent active.
    match /notifications/{notificationId} {
      allow create: if isSignedIn()
        && request.resource.data.userId is string
        && request.resource.data.keys().hasAll([
          'userId',
          'type',
          'title',
          'body',
          'isRead',
          'createdAt'
        ]);
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead'])
        );
      allow delete: if isAdmin();
    }

    // Liste blanche des emails admin (doc id = email en minuscule)
    match /admin_emails/{emailId} {
      allow read, write: if isAdmin();
    }
  }
}
